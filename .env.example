# Salin ke .env dan isi nilai Anda. JANGAN commit .env.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/sobatpaws

# --- Auth API (opsional; kosong = mode dev tanpa auth) ---
SOBATPAWS_VET_API_KEY=
SOBATPAWS_ADMIN_API_KEY=

# --- AI Provider utama ---
# openai | anthropic | local (Ollama/vLLM OpenAI-compatible)
SOBATPAWS_AI_PROVIDER=local

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
# Model Claude — lihat https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Aktifkan Claude sebagai provider utama:
# SOBATPAWS_AI_PROVIDER=anthropic

# Model lokal (Ollama default)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=llama3.2

# Efisiensi token
SOBATPAWS_AI_TEMPERATURE=0.2
SOBATPAWS_AI_MAX_TOKENS=800
SOBATPAWS_AI_AUGMENTATION_MODE=smart
SOBATPAWS_AI_DAILY_TOKEN_BUDGET=0
SOBATPAWS_AI_CACHE_TTL_SEC=3600
SOBATPAWS_AI_SKIP_LLM_CONFIDENCE=0.82
SOBATPAWS_AI_FALLBACK_CHAIN=local,openai,anthropic

# --- Learning store (konsultasi & input dokter) ---
# jsonl | postgres | both
SOBATPAWS_LEARNING_BACKEND=jsonl

# --- Agent AI store (saran, chat, request log) ---
# jsonl | postgres | both
SOBATPAWS_AI_STORE_BACKEND=jsonl
